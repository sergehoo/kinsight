# ============================================================================
# k-insight — variables d'environnement (exemple). Copier en .env et compléter.
# ============================================================================

# --- Backend Django ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:8080
GUNICORN_WORKERS=3
FRONTEND_PORT=8080
VITE_API_TOKEN=

# --- Base applicative Django (schéma `app`, séparée des données analytiques, ADR-0004) ---
POSTGRES_PASSWORD=change-me
APP_DB_HOST=postgres
APP_DB_PORT=5432
APP_DB_NAME=k_insight_app
APP_DB_USER=k_insight_app
APP_DB_PASSWORD=change-me

# --- EDW PostgreSQL (lecture seule sur mart/analytics depuis le backend, ADR-0004) ---
EDW_DB_HOST=postgres
EDW_DB_PORT=5432
EDW_DB_NAME=k_insight_edw
EDW_DB_USER=k_insight_app
EDW_DB_PASSWORD=change-me
SEED_DEMO_DATA=false

# --- dbt (rôle de transformation, droits d'écriture staging/warehouse/mart) ---
DBT_DB_USER=k_insight_dbt
DBT_DB_PASSWORD=change-me

# --- Airbyte (EL, ADR-0003) : rôle loader, droits CREATE/écriture sur le schéma raw ---
# Airbyte lui-même se déploie hors compose via `abctl` — voir infra/airbyte/README.md.
AIRBYTE_DB_USER=k_insight_airbyte
AIRBYTE_DB_PASSWORD=change-me

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# --- IA (copilote ancré, ADR-0007) ---
ANTHROPIC_API_KEY=change-me
# Modèles Claude les plus récents (voir docs Anthropic).
AI_MODEL_SYNTHESIS=claude-opus-4-8

# --- Stockage objet (exports PDF/Excel) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=k-insight-exports

# --- Ports publiés (dev) — surcharger pour éviter les conflits sur la machine hôte ---
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
BACKEND_PORT=8000
# FRONTEND_PORT déjà défini plus haut (8080)
ADMINER_PORT=8081

# --- dbt (runner conteneurisé, profil "dbt") ---
# Schéma cible par défaut des transformations dbt.
DBT_SCHEMA=warehouse
