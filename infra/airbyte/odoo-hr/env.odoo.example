# Paramètres de connexion Odoo RH — À RENSEIGNER chez vous (NE PAS versionner avec la vraie clé).
# Copier en `.env.odoo` (gitignored) ou injecter via votre secret manager.
# Utilisé par : scripts/odoo_hr_preflight.py et la config source Airbyte.

ODOO_URL=https://odoo.kaydan.tech     # base URL de l'instance Odoo
ODOO_DB=kaydan_rh                      # nom de la base Odoo
ODOO_LOGIN=api@kaydan.tech             # login de l'utilisateur API (lecture RH)
# La clé API NE DOIT PAS être commitée. Injectez-la au runtime :
#   export ODOO_API_KEY="$(votre-secret-manager get odoo_rh_api_key)"
ODOO_API_KEY=
ODOO_VERSION=17                        # version Odoo (informatif)
